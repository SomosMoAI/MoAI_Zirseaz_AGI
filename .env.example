# ============================================================
# MAMM — Configuración de Credenciales
# ============================================================
# Completa TELEGRAM_BOT_TOKEN y TELEGRAM_CHAT_ID con los datos
# de tu bot (crea uno en @BotFather si no tienes).
# Tu Chat ID lo consigues hablando con @userinfobot en Telegram.
# ============================================================

# --- Telegram Bot (para notificaciones HITL) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- n8n Webhooks (activos en sebacuevas.app.n8n.cloud) ---
N8N_WEBHOOK_IMAGE=https://sebacuevas.app.n8n.cloud/webhook/mamm-generate-image
N8N_WEBHOOK_PUBLISH=https://sebacuevas.app.n8n.cloud/webhook/mamm-publish-post

# --- Zirseaz Email Manager ---
ZIRSEAZ_EMAIL=tu_correo@gmail.com
ZIRSEAZ_PASSWORD=tu_contraseña_de_aplicacion_gmail

# --- Zirseaz Web Master (FTP Hosting) ---
HOSTING_HOST=ftp.tudominio.com
HOSTING_USER=usuario_cpanel
HOSTING_PASS=contraseña_ftp

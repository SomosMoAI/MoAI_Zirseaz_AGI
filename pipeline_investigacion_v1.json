{
  "pipeline_name": "investigacion_automatizada_v1",
  "version": "1.0",
  "created": "2026-05-11",
  "description": "Pipeline de investigación automatizada que busca, extrae y resume información de la web",
  "components": [
    {
      "name": "motor_busqueda",
      "skills": [
        "buscar_en_web",
        "buscar_noticias_newsapi"
      ],

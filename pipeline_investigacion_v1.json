    },
    {
      "name": "extractor_contenido",
      "skills": [
        "leer_contenido_url",
        "scrape_url",
        "extraer_urls"
      ],
      "description": "Extrae y procesa contenido de URLs"
    },
    {
      "name": "analizador_datos",
      "skills": [
        "enviar_peticion_get",
        "contar_palabras",
        "calcular_hash_archivo"
      ],
      "description": "Analiza y procesa los datos extraídos"
